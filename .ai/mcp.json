{
  "mcp_version": "1.0.0",
  "operations": {
    "build": {
      "command": "yarn build",
      "description": "Compiles the project and checks for build errors.",
      "critical": true
    },
    "test": {
      "command": "yarn test",
      "description": "Runs all unit and integration tests.",
      "critical": true
    },
    "lint": {
      "command": "yarn lint",
      "description": "Runs the linter to ensure code quality.",
      "critical": true
    },
    "doc-gen": {
      "command": "yarn build:docs",
      "description": "Generates documentation from source code.",
      "critical": false
    },
    "clean": {
      "command": "yarn clean",
      "description": "Cleans the build artifacts.",
      "critical": false
    }
  },
  "configurations": {
    "package_manager": "yarn",
    "environment": "node"
  }
}
